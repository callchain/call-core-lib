{
  "name": "call-core-lib",
  "version": "1.0.0",
  "description": "TypeScript/JavaScript client library for Call-Core blockchain",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "browser": "dist/browser/call-core-lib.min.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:types && npm run build:cjs && npm run build:esm && npm run build:browser",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/types",
    "build:cjs": "tsc --module commonjs --outDir dist/cjs",
    "build:esm": "tsc --module esnext --outDir dist/esm",
    "build:browser": "webpack --mode production",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "call-core",
    "blockchain",
    "cryptocurrency",
    "rpc",
    "websocket",
    "api",
    "client",
    "typescript"
  ],
  "author": "Call-Core Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/call-core/call-core-lib.git"
  },
  "bugs": {
    "url": "https://github.com/call-core/call-core-lib/issues"
  },
  "homepage": "https://github.com/call-core/call-core-lib#readme",
  "devDependencies": {
    "@types/elliptic": "^6.4.18",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "bignumber.js": "^9.1.2",
    "bn.js": "^5.2.1",
    "elliptic": "^6.5.4",
    "hash.js": "^1.1.7",
    "isomorphic-ws": "^5.0.0",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
